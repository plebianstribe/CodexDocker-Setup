# Copy this file to .env and fill values before docker run.

# Required by scripts/createcodexconfig.sh (canonical URL key).
CODEX_BASE_URL=

# Required API key (used by CODEX_API_ENV_KEY default: CODEX_API_KEY).
CODEX_API_KEY=

# Used by docker run/runtime inside the container.
# Default to /workspace so Codex state/config live in the repo mount.
# Note: createcodexconfig.sh always writes to ./.codex/config.toml on host.
CODEX_CONFIG=/workspace/.codex/config.toml
CODEX_HOME=/workspace/.codex

# Optional overrides for createcodexconfig.sh (defaults shown by script if unset):
# CODEX_MODEL_PROVIDER=azure
# CODEX_MODEL=gpt-5.4
# CODEX_MODEL_REASONING_EFFORT=low
# CODEX_API_ENV_KEY=CODEX_API_KEY

# Alternative accepted URL keys:
# REMOTEURL=
# CODEX_BASE_URL=
# REMOTE_URL=
# AZURE_OPENAI_BASE_URL=
